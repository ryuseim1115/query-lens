{
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "htmlhint": "^1.1.0",
    "prettier": "^3.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0"
  },
  "scripts": {
    "lint:js": "eslint \"js/**/*.js\"",
    "lint:html": "htmlhint \"html/**/*.html\"",
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint": "npm run lint:js && npm run lint:html && npm run lint:css",
    "format": "prettier --write \"**/*.{js,html,css}\""
  },
  "prettier": {
    "printWidth": 88,
    "singleQuote": true,
    "semi": true,
    "tabWidth": 2
  },
  "htmlhint": {
    "doctype-first": true,
    "tag-pair": true,
    "attr-lowercase": true,
    "attr-value-double-quotes": true,
    "id-unique": true
  },
  "stylelint": {
    "extends": "stylelint-config-standard"
  }
}
